---
import Button from "@/components/ui/Button.astro";
import RegistrationForm from "@/components/forms/RegistrationForm.astro";
import type { Locale } from "@/data/locales";

type MetaCard = {
  label: string;
  value: string;
};

type SectionCard = {
  eyebrow: string;
  title: string;
  text?: string;
  list?: string[];
};

type PriceCard = {
  eyebrow: string;
  title: string;
  price: string;
  text: string;
};

type FaqItem = {
  question: string;
  answer: string;
};

type CTA = {
  eyebrow: string;
  title: string;
  text: string;
  primary: string;
  secondary: string;
};

type LandingContent = {
  eyebrow: string;
  title: string;
  description: string;
  imageSrc: string;
  imageAlt: string;
  imageCaption: string;
  primaryCta: string;
  secondaryCta: string;
  secondaryHref: string;
  metaCards: MetaCard[];
  topSections: SectionCard[];
  midSections?: SectionCard[];
  priceSection: {
    eyebrow: string;
    title: string;
    text: string;
    cards: PriceCard[];
  };
  faqItems: FaqItem[];
  cta: CTA;
};

const { content, locale = "et" } = Astro.props as { content: LandingContent; locale?: Locale };

const labels = {
  et: { faqEyebrow: "KKK", faqTitle: "Levinud küsimused enne alustamist" },
  ru: { faqEyebrow: "FAQ", faqTitle: "Частые вопросы перед началом" },
  en: { faqEyebrow: "FAQ", faqTitle: "Common questions before you start" },
} as const;

const copy = labels[locale];
---

<section class="section">
  <div class="container landing-hero">
    <div class="landing-hero__content">
      <div class="eyebrow">{content.eyebrow}</div>
      <h1 class="section-title">{content.title}</h1>
      <p class="section-text">{content.description}</p>
      <div class="button-row" style="margin-top:24px">
        <Button href="#registration">{content.primaryCta}</Button>
        <Button href={content.secondaryHref} variant="secondary">{content.secondaryCta}</Button>
      </div>
      <div class="landing-hero__meta">
        {content.metaCards.map((item) => (
          <div class="landing-meta-card">
            <span>{item.label}</span>
            <strong>{item.value}</strong>
          </div>
        ))}
      </div>
    </div>
    <div class="hero-image-wrap hero-image-wrap--enhanced">
      <img src={content.imageSrc} alt={content.imageAlt} />
      <div class="hero-image-caption">{content.imageCaption}</div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container grid grid-2">
    {content.topSections.map((section) => (
      <article class="card fact-card">
        <div class="eyebrow">{section.eyebrow}</div>
        <h2 class="section-title">{section.title}</h2>
        {section.text && <p class="section-text">{section.text}</p>}
        {section.list && (
          <ul class="info-list">
            {section.list.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        )}
      </article>
    ))}
  </div>
</section>

{content.midSections && content.midSections.length > 0 && (
  <section class="section">
    <div class="container grid grid-2">
      {content.midSections.map((section) => (
        <article class="card fact-card">
          <div class="eyebrow">{section.eyebrow}</div>
          <h2 class="section-title">{section.title}</h2>
          {section.text && <p class="section-text">{section.text}</p>}
          {section.list && (
            <ul class="info-list">
              {section.list.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          )}
        </article>
      ))}
    </div>
  </section>
)}

<section class="section">
  <div class="container">
    <div class="eyebrow">{content.priceSection.eyebrow}</div>
    <h2 class="section-title">{content.priceSection.title}</h2>
    <p class="section-text">{content.priceSection.text}</p>
    <div class="price-grid" style="margin-top:20px">
      {content.priceSection.cards.map((card) => (
        <article class="card price-card">
          <div class="eyebrow">{card.eyebrow}</div>
          <h3>{card.title}</h3>
          <div class="price-card__value">{card.price}</div>
          <p class="muted">{card.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="eyebrow">{copy.faqEyebrow}</div>
    <h2 class="section-title">{copy.faqTitle}</h2>
    <div class="faq-grid">
      {content.faqItems.map((item) => (
        <article class="faq-item">
          <h3>{item.question}</h3>
          <p class="section-text">{item.answer}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="section">
  <div class="container cta-band">
    <div class="section-shell">
      <div class="eyebrow">{content.cta.eyebrow}</div>
      <h2 class="section-title">{content.cta.title}</h2>
      <p class="section-text">{content.cta.text}</p>
    </div>
    <div class="button-row">
      <Button href="#registration">{content.cta.primary}</Button>
      <Button href="tel:+3725114740" variant="secondary">{content.cta.secondary}</Button>
    </div>
  </div>
</section>

<RegistrationForm locale={locale} />
