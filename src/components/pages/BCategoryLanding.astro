---
import Button from "@/components/ui/Button.astro";
import RegistrationForm from "@/components/forms/RegistrationForm.astro";
import type { Locale } from "@/data/locales";

type FAQItem = {
  question: string;
  answer: string;
};

type Testimonial = {
  quote: string;
  author: string;
};

type MetaCard = {
  label: string;
  value: string;
};

type BLandingContent = {
  eyebrow: string;
  title: string;
  description: string;
  primaryCta: string;
  secondaryCta: string;
  secondaryHref: string;
  imageSrc: string;
  imageAlt: string;
  imageCaption: string;
  metaCards: MetaCard[];
  firstSection: {
    eyebrow: string;
    title: string;
    text: string;
  };
  secondSection: {
    eyebrow: string;
    title: string;
    list: string[];
  };
  thirdSection: {
    eyebrow: string;
    title: string;
    text: string;
  };
  fourthSection: {
    eyebrow: string;
    title: string;
    text: string;
  };
  priceSection: {
    eyebrow: string;
    title: string;
    text: string;
    cards: Array<{ eyebrow: string; title: string; price: string; text: string }>;
  };
  testimonialSection: {
    eyebrow: string;
    title: string;
    items: Testimonial[];
  };
  faqSection: {
    eyebrow: string;
    title: string;
    items: FAQItem[];
  };
  ctaSection: {
    eyebrow: string;
    title: string;
    text: string;
    primary: string;
    secondary: string;
  };
  contactSection: {
    eyebrow: string;
    title: string;
    items: string[];
  };
};

const { content, locale = "et" } = Astro.props as { content: BLandingContent; locale?: Locale };
---

<section class="section">
  <div class="container landing-hero">
    <div class="landing-hero__content">
      <div class="eyebrow">{content.eyebrow}</div>
      <h1 class="section-title">{content.title}</h1>
      <p class="section-text">{content.description}</p>
      <div class="button-row" style="margin-top:24px">
        <Button href="#registration">{content.primaryCta}</Button>
        <Button href={content.secondaryHref} variant="secondary">{content.secondaryCta}</Button>
      </div>
      <div class="landing-hero__meta">
        {content.metaCards.map((item) => (
          <div class="landing-meta-card">
            <span>{item.label}</span>
            <strong>{item.value}</strong>
          </div>
        ))}
      </div>
    </div>
    <div class="hero-image-wrap hero-image-wrap--enhanced">
      <img src={content.imageSrc} alt={content.imageAlt} />
      <div class="hero-image-caption">{content.imageCaption}</div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container grid grid-2">
    <article class="card fact-card">
      <div class="eyebrow">{content.firstSection.eyebrow}</div>
      <h2 class="section-title">{content.firstSection.title}</h2>
      <p class="section-text">{content.firstSection.text}</p>
    </article>
    <article class="card fact-card">
      <div class="eyebrow">{content.secondSection.eyebrow}</div>
      <h2 class="section-title">{content.secondSection.title}</h2>
      <ul class="info-list">
        {content.secondSection.list.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </article>
  </div>
</section>

<section class="section">
  <div class="container grid grid-2">
    <article class="card fact-card">
      <div class="eyebrow">{content.thirdSection.eyebrow}</div>
      <h2 class="section-title">{content.thirdSection.title}</h2>
      <p class="section-text">{content.thirdSection.text}</p>
    </article>
    <article class="card fact-card">
      <div class="eyebrow">{content.fourthSection.eyebrow}</div>
      <h2 class="section-title">{content.fourthSection.title}</h2>
      <p class="section-text">{content.fourthSection.text}</p>
    </article>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="eyebrow">{content.priceSection.eyebrow}</div>
    <h2 class="section-title">{content.priceSection.title}</h2>
    <p class="section-text">{content.priceSection.text}</p>
    <div class="price-grid" style="margin-top:20px">
      {content.priceSection.cards.map((card) => (
        <article class="card price-card">
          <div class="eyebrow">{card.eyebrow}</div>
          <h3>{card.title}</h3>
          <div class="price-card__value">{card.price}</div>
          <p class="muted">{card.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="eyebrow">{content.testimonialSection.eyebrow}</div>
    <h2 class="section-title">{content.testimonialSection.title}</h2>
    <div class="grid grid-2">
      {content.testimonialSection.items.map((item) => (
        <article class="card quote-card">
          <p>{item.quote}</p>
          <strong>{item.author}</strong>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="eyebrow">{content.faqSection.eyebrow}</div>
    <h2 class="section-title">{content.faqSection.title}</h2>
    <div class="faq-grid">
      {content.faqSection.items.map((item) => (
        <article class="faq-item">
          <h3>{item.question}</h3>
          <p class="section-text">{item.answer}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="section">
  <div class="container cta-band">
    <div class="section-shell">
      <div class="eyebrow">{content.ctaSection.eyebrow}</div>
      <h2 class="section-title">{content.ctaSection.title}</h2>
      <p class="section-text">{content.ctaSection.text}</p>
    </div>
    <div class="button-row">
      <Button href="#registration">{content.ctaSection.primary}</Button>
      <Button href="tel:+3725114740" variant="secondary">{content.ctaSection.secondary}</Button>
    </div>
  </div>
</section>

<section class="section">
  <div class="container contact-layout">
    <article class="card fact-card">
      <div class="eyebrow">{content.contactSection.eyebrow}</div>
      <h2 class="section-title">{content.contactSection.title}</h2>
      <ul class="info-list">
        {content.contactSection.items.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </article>
    <div class="contact-layout__form">
      <RegistrationForm locale={locale} />
    </div>
  </div>
</section>
