---
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import { categoryCards } from "@/data/categories";
import type { Locale } from "@/data/locales";

const { locale = "et" } = Astro.props as { locale?: Locale };
const labels = {
  et: { eyebrow: "Meie kursused", title: "Vali sobiv kategooria", view: "Vaata", register: "Registreeru" },
  ru: { eyebrow: "Наши курсы", title: "Выберите подходящую категорию", view: "Подробнее", register: "Записаться" },
  en: { eyebrow: "Our Courses", title: "Choose the right category", view: "View", register: "Register" },
} as const;
const copy = labels[locale];
const motorcycleKeys = ["a", "a1", "a2", "am"];
---

<section class="section">
  <Container>
    <div class="eyebrow">{copy.eyebrow}</div>
    <h2 class="section-title">{copy.title}</h2>
    <div class="grid grid-3">
      {categoryCards[locale].map((card) => (
        <article class={`card category-card category-card--${card.key}`} style="padding:24px">
          <div class="category-card__image-wrap">
            <img src={card.image} alt={card.subtitle} class={`category-card__image ${motorcycleKeys.includes(card.key) ? "category-card__image--motorcycle category-card__image--blend" : "category-card__image--contain"}`} />
          </div>
          <div class="category-card__title">{card.title}</div>
          <p class="muted">{card.subtitle}</p>
          <p style="margin:0 0 8px">{card.excerpt}</p>
          <div class="category-meta">
            <span><strong>{card.price}</strong></span>
            <span>{card.lessons}</span>
            <span>{card.age}</span>
          </div>
          <div class="button-row">
            <Button href={card.href} variant="secondary">{copy.view}</Button>
            <Button href="#registration">{copy.register}</Button>
          </div>
        </article>
      ))}
    </div>
  </Container>
</section>
