---
import type { Locale } from "@/data/locales";

const labels = {
  et: {
    title: "Registreerimisvorm",
    fullName: "Nimi ja perekonnanimi",
    personalCode: "Isikukood",
    phone: "Telefon",
    email: "E-post",
    category: "Kategooria",
    studyLanguage: "Õppekeel",
    courseStartDate: "Kursuse alguskuupäev",
    comment: "Kommentaar",
    submitting: "Saadame teie taotlust...",
    success: "Aitah! Registreerimine on saadetud.",
    invalid: "Palun täitke kohustuslikud väljad.",
    error: "Saatmine ebaõnnestus. Proovige uuesti või võtke meiega ühendust.",
    submit: "Saada päring",
  },
  ru: {
    title: "Форма регистрации",
    fullName: "Имя и фамилия",
    personalCode: "Личный код",
    phone: "Телефон",
    email: "Email",
    category: "Категория",
    studyLanguage: "Язык обучения",
    courseStartDate: "Дата начала курса",
    comment: "Комментарий",
    submitting: "Отправляем вашу заявку...",
    success: "Спасибо! Заявка отправлена.",
    invalid: "Пожалуйста, заполните обязательные поля.",
    error: "Не удалось отправить заявку. Попробуйте еще раз или свяжитесь с нами.",
    submit: "Отправить заявку",
  },
  en: {
    title: "Registration form",
    fullName: "Full name",
    personalCode: "Personal ID code",
    phone: "Phone",
    email: "Email",
    category: "Category",
    studyLanguage: "Study language",
    courseStartDate: "Course start date",
    comment: "Comment",
    submitting: "Sending your request...",
    success: "Thank you! Your registration has been sent.",
    invalid: "Please fill in the required fields.",
    error: "We could not send your request. Please try again or contact us.",
    submit: "Submit request",
  },
} as const;

const { locale = "et" } = Astro.props as { locale?: Locale };
const copy = labels[locale];
const sourcePath = Astro.url.pathname;
---

<section class="section" id="registration">
  <div class="container">
    <div class="card" style="padding:24px">
      <div class="eyebrow">Lead form</div>
      <h2 class="section-title">{copy.title}</h2>
      <form
        class="form-grid"
        method="post"
        action="/api/registration"
        data-registration-form
        data-submitting-message={copy.submitting}
        data-success-message={copy.success}
        data-invalid-message={copy.invalid}
        data-error-message={copy.error}
      >
        <input name="sourcePath" type="hidden" value={sourcePath} />
        <input name="locale" type="hidden" value={locale} />
        <input
          name="company"
          type="text"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
          style="position:absolute;left:-9999px;opacity:0"
        />
        <label class="field field-full">
          <span>{copy.fullName}</span>
          <input name="fullName" autocomplete="name" required />
        </label>
        <label class="field">
          <span>{copy.personalCode}</span>
          <input name="personalCode" />
        </label>
        <label class="field">
          <span>{copy.phone}</span>
          <input name="phone" type="tel" autocomplete="tel" required />
        </label>
        <label class="field">
          <span>{copy.email}</span>
          <input name="email" type="email" autocomplete="email" required />
        </label>
        <label class="field">
          <span>{copy.category}</span>
          <select name="category" required>
            <option value="">--</option>
            <option>AM</option>
            <option>A1</option>
            <option>A2</option>
            <option>A</option>
            <option>B</option>
            <option>BE</option>
          </select>
        </label>
        <label class="field">
          <span>{copy.studyLanguage}</span>
          <select name="studyLanguage" required>
            <option value="">--</option>
            <option>EST</option>
            <option>RU</option>
            <option>ENG</option>
          </select>
        </label>
        <label class="field">
          <span>{copy.courseStartDate}</span>
          <input name="courseStartDate" type="date" />
        </label>
        <label class="field field-full">
          <span>{copy.comment}</span>
          <textarea name="comment"></textarea>
        </label>
        <div class="field field-full">
          <button class="button button-primary" type="submit">{copy.submit}</button>
        </div>
        <p class="field field-full" data-form-status aria-live="polite"></p>
      </form>
    </div>
  </div>
</section>

<script is:inline>
  const registrationForms = document.querySelectorAll("[data-registration-form]");

  for (const form of registrationForms) {
    if (!(form instanceof HTMLFormElement) || form.dataset.bound === "true") {
      continue;
    }

    form.dataset.bound = "true";

    const submitButton = form.querySelector('button[type="submit"]');
    const status = form.querySelector("[data-form-status]");

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      if (!form.reportValidity()) {
        if (status instanceof HTMLElement) {
          status.textContent = form.dataset.invalidMessage || "";
        }
        return;
      }

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
      }

      if (status instanceof HTMLElement) {
        status.textContent = form.dataset.submittingMessage || "";
      }

      try {
        const response = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
        });

        if (!response.ok) {
          let errorMessage = form.dataset.errorMessage || "";

          try {
            const data = await response.json();

            if (typeof data.message === "string" && data.message.trim()) {
              errorMessage = `${errorMessage} (${data.message.trim()})`;
            }
          } catch {
            // Ignore invalid JSON and show the generic message.
          }

          throw new Error(errorMessage || `Request failed with status ${response.status}`);
        }

        form.reset();

        if (status instanceof HTMLElement) {
          status.textContent = form.dataset.successMessage || "";
        }
      } catch (error) {
        console.error(error);

        if (status instanceof HTMLElement) {
          status.textContent =
            error instanceof Error && error.message ? error.message : form.dataset.errorMessage || "";
        }
      } finally {
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = false;
        }
      }
    });
  }
</script>

