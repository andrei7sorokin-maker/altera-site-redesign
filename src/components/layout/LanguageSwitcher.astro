---
import { defaultLocale, localeLabels, locales, type Locale } from "@/data/locales";
import { getLocalizedPath } from "@/data/seo";

const { currentLocale = defaultLocale, currentPath = "/" } = Astro.props as { currentLocale?: Locale; currentPath?: string };
---

<nav aria-label="Language switcher" class="site-nav">
  {locales.map((locale) => (
    <a
      href={getLocalizedPath(currentPath, locale)}
      style={locale === currentLocale ? "font-weight:700;color:var(--color-navy)" : "color:var(--color-muted)"}
    >
      {localeLabels[locale]}
    </a>
  ))}
</nav>
