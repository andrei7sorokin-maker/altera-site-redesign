---
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import LanguageSwitcher from "@/components/layout/LanguageSwitcher.astro";
import ClientPortalButton from "@/components/layout/ClientPortalButton.astro";
import { navigation } from "@/data/navigation";
import type { Locale } from "@/data/locales";

const { locale = "et" } = Astro.props as { locale?: Locale };

const registerHref = locale === "et" ? "/#registration" : locale === "ru" ? "/ru/#registration" : "/en/#registration";
const registerLabel = locale === "et" ? "Registreeru" : locale === "ru" ? "Записаться" : "Register";
const homeHref = locale === "et" ? "/" : `/${locale}/`;
---

<header class="site-header">
  <Container>
    <div class="site-header__inner">
      <a href={homeHref} style="display:inline-flex;align-items:center">
        <img src="/images/logo/altera-logo.png" alt="Altera" class="logo-mark" />
      </a>
      <nav class="site-nav" aria-label="Primary">
        {navigation[locale].map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </nav>
      <div class="button-row">
        <LanguageSwitcher currentLocale={locale} />
        <ClientPortalButton locale={locale} />
        <Button href={registerHref}>{registerLabel}</Button>
      </div>
    </div>
  </Container>
</header>
