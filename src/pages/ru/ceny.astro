---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout locale="ru" title="Цены | Altera" description="Цены курсов Altera">
  <section class="section">
    <div class="container section-shell">
      <div class="eyebrow">Цены</div>
      <h1 class="section-title">Стоимость курсов автошколы</h1>
      <div class="price-grid">
        <article class="card price-card"><div class="eyebrow">AM</div><h2>Права на мопед</h2><div class="price-card__value">690 €</div><p class="muted">24ч теория, 12ч практика, с 14 лет.</p></article>
        <article class="card price-card"><div class="eyebrow">A</div><h2>Права на мотоцикл</h2><div class="price-card__value">590 €</div><p class="muted">10ч теория, 10ч практика, с 24 лет.</p></article>
        <article class="card price-card"><div class="eyebrow">B</div><h2>Права на автомобиль</h2><div class="price-card__value">910 €</div><p class="muted">29ч теория, 28ч вождения и школьный экзамен.</p></article>
        <article class="card price-card"><div class="eyebrow">BE</div><h2>Автомобиль с прицепом</h2><div class="price-card__value">350 €</div><p class="muted">4ч теория, 4ч практика, нужна категория B.</p></article>
      </div>
    </div>
  </section>
</BaseLayout>
