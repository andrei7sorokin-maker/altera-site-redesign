---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Button from "@/components/ui/Button.astro";
import RegistrationForm from "@/components/forms/RegistrationForm.astro";
---

<BaseLayout
  locale="et"
  title="Kontakt | Autokool Tallinnas | Altera Autokool"
  description="Võta ühendust Altera Autokooliga Tallinnas. Telefon, e-post, aadress, registreerimine ja kursuse info."
>
  <section class="section">
    <div class="container section-shell">
      <div class="eyebrow">Kontakt</div>
      <h1 class="section-title">Kontakt</h1>
      <p class="section-text">
        Kui soovid küsida lisainfot, registreeruda kursusele või täpsustada sobivat algust, võta meiega ühendust
        telefoni, e-posti või vormi kaudu.
      </p>
      <div class="button-row">
        <Button href="tel:+3725114740">Helista</Button>
        <Button href="mailto:info@altera.ee" variant="secondary">Saada e-kiri</Button>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid grid-2">
      <article class="card fact-card">
        <div class="eyebrow">Kontaktandmed</div>
        <h2 class="section-title">Altera Autokool Tallinnas</h2>
        <ul class="info-list">
          <li><strong>Telefon:</strong> +372 511 47 40</li>
          <li><strong>E-post:</strong> info@altera.ee</li>
          <li><strong>Aadress:</strong> Narva mnt. 4 – 204, II korrus, Tallinn</li>
          <li><strong>Lahtioleku info:</strong> dokumentide vastuvõtt kolmapäeviti 15:00 - 18:00</li>
          <li><strong>Peatus:</strong> Hobujaama, tramm 1 ja 3</li>
          <li><strong>Ettevõte:</strong> Altera Autokool OÜ, reg.nr. 11950064</li>
        </ul>
      </article>
      <article class="card fact-card">
        <div class="eyebrow">Kuidas kohale tulla</div>
        <h2 class="section-title">Lihtne leida ka ühistranspordiga</h2>
        <ul class="info-list">
          <li><strong>Asukoht:</strong> Tallinna kesklinn, Narva mnt 4-204</li>
          <li><strong>Peatus:</strong> Hobujaama</li>
          <li><strong>Trammid:</strong> 1 ja 3</li>
          <li><strong>Registreerimine:</strong> veebis, telefoni või e-posti teel</li>
        </ul>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-map">
        <iframe
          title="Altera Autokool kaart"
          src="https://www.google.com/maps?q=Narva%20mnt%204%20Tallinn&output=embed"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container contact-layout">
      <article class="card fact-card">
        <div class="eyebrow">Kiire kontakt</div>
        <h2 class="section-title">Küsi infot või saada registreerimispäring</h2>
        <p class="section-text">
          Kui Sa ei ole kindel, milline kategooria sobib või millal on mõistlik alustada, kirjuta meile. Aitame teha
          esimese sammu lihtsamaks ja anname ülevaate järgmistest võimalustest.
        </p>
        <div class="button-row" style="margin-top:24px">
          <Button href="tel:+3725114740">Helista kohe</Button>
          <Button href="mailto:info@altera.ee" variant="secondary">Kirjuta meile</Button>
        </div>
      </article>
      <div class="contact-layout__form">
        <RegistrationForm locale="et" />
      </div>
    </div>
  </section>
</BaseLayout>
