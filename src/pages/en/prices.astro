---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout locale="en" title="Prices | Altera" description="Altera course prices">
  <section class="section">
    <div class="container section-shell">
      <div class="eyebrow">Prices</div>
      <h1 class="section-title">Driving school course prices</h1>
      <div class="price-grid">
        <article class="card price-card"><div class="eyebrow">AM</div><h2>Moped licence</h2><div class="price-card__value">690 €</div><p class="muted">24h theory, 12h practice, from age 14.</p></article>
        <article class="card price-card"><div class="eyebrow">A</div><h2>Motorcycle licence</h2><div class="price-card__value">590 €</div><p class="muted">10h theory, 10h practice, from age 24.</p></article>
        <article class="card price-card"><div class="eyebrow">B</div><h2>Passenger car licence</h2><div class="price-card__value">910 €</div><p class="muted">29h theory, 28h driving and a school theory exam.</p></article>
        <article class="card price-card"><div class="eyebrow">BE</div><h2>Car with trailer</h2><div class="price-card__value">350 €</div><p class="muted">4h theory, 4h practice, B-category licence required.</p></article>
      </div>
    </div>
  </section>
</BaseLayout>
