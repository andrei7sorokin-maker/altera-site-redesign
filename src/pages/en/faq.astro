---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout locale="en" title="FAQ | Altera" description="Frequently asked questions">
  <section class="section">
    <div class="container section-shell">
      <div class="eyebrow">FAQ</div>
      <h1 class="section-title">Frequently asked questions</h1>
      <div class="faq-grid">
        <article class="faq-item"><h3>At what age can I start category B?</h3><p class="section-text">You can register for the course from the age of 15.5. State exams can be taken within the legal timeframe.</p></article>
        <article class="faq-item"><h3>What is required for AM registration?</h3><p class="section-text">Parent permission, a valid medical certificate and a digital photo are required. The minimum age is 14.</p></article>
        <article class="faq-item"><h3>Do I need an existing licence for category A?</h3><p class="section-text">Yes, a valid driving licence in any category is required to register for A-category training. The minimum age is 24.</p></article>
        <article class="faq-item"><h3>What is BE used for?</h3><p class="section-text">It is needed for a category B car with a trailer over 750 kg, including a boat trailer.</p></article>
      </div>
    </div>
  </section>
</BaseLayout>
