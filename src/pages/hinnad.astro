---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout locale="et" title="Hinnad | Altera" description="Altera autokooli kursuste hinnad">
  <section class="section">
    <div class="container section-shell">
      <div class="eyebrow">Hinnad</div>
      <h1 class="section-title">Autokooli kursuste hinnad</h1>
      <p class="section-text">Allpool on põhiandmed Altera praegustelt kursustelehtedelt. Täpsem registreerimine ja kursuse algus valitakse vormis.</p>
      <div class="price-grid">
        <article class="card price-card">
          <div class="eyebrow">AM</div>
          <h2>Mopedi juhiload</h2>
          <div class="price-card__value">690 €</div>
          <p class="muted">24 teooriatundi, 12 praktikatundi, alates 14. eluaastast.</p>
        </article>
        <article class="card price-card">
          <div class="eyebrow">A</div>
          <h2>Mootorratta juhiload</h2>
          <div class="price-card__value">590 €</div>
          <p class="muted">10 teooriatundi, 10 praktikatundi, alates 24. eluaastast.</p>
        </article>
        <article class="card price-card">
          <div class="eyebrow">B</div>
          <h2>Sõiduauto juhiload</h2>
          <div class="price-card__value">910 €</div>
          <p class="muted">29 teooriatundi, 28 sõidutundi ja autokooli teooriaeksam.</p>
        </article>
        <article class="card price-card">
          <div class="eyebrow">BE</div>
          <h2>Sõiduauto haagisega</h2>
          <div class="price-card__value">350 €</div>
          <p class="muted">4 teooriatundi, 4 praktikatundi, vajalik B-kategooria juhiluba.</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
